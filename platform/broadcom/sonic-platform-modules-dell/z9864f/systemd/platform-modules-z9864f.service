[Unit]
Description=Dell Z9864F Platform modules
Before=pmon.service
After=platform-init.service
Before=platform-ready.service
DefaultDependencies=no

[Service]
Type=oneshot
ExecStart=/usr/local/bin/z9864f_platform.sh init
ExecStop=/usr/local/bin/z9864f_platform.sh deinit
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
