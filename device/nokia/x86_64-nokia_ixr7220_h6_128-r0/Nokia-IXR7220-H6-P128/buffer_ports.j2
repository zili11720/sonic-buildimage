{%- macro generate_port_lists(PORT_ALL) %}
    {# Generate list of ports #}
    {%- for port_idx in range(0, 1024, 8) %}
        {%- if PORT_ALL.append("Ethernet%d" % (port_idx)) %}{%- endif %}
    {%- endfor %}
    {% if PORT_ALL.append("Ethernet1024") %}{% endif %}
    {% if PORT_ALL.append("Ethernet1025") %}{% endif %}
{%- endmacro %}
