SPATH       := $($(MAKEDUMPFILE)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/makedumpfile.mk rules/makedumpfile.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(SPATH))

$(MAKEDUMPFILE)_CACHE_MODE  := GIT_CONTENT_SHA
$(MAKEDUMPFILE)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(MAKEDUMPFILE)_DEP_FILES   := $(DEP_FILES)
