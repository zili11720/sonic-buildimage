# makedumpfile package

MAKEDUMPFILE_VERSION = 1.7.7
MAKEDUMPFILE_DEB_REVISION = 1

MAKEDUMPFILE = makedumpfile_$(MAKEDUMPFILE_VERSION)-$(MAKEDUMPFILE_DEB_REVISION)_$(CONFIGURED_ARCH).deb
$(MAKEDUMPFILE)_SRC_PATH = $(SRC_PATH)/makedumpfile
SONIC_MAKE_DEBS += $(MAKEDUMPFILE)

export MAKEDUMPFILE_VERSION
export MAKEDUMPFILE_DEB_REVISION
export MAKEDUMPFILE
